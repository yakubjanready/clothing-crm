# =========================================================================
# Production environment — Hetzner deploy uchun.
# `cp .env.prod.example .env.prod` va qiymatlarni almashtiring.
# `.env.prod` GIT'GA TUSHMASIN (gitignore'da `.env.*` allaqachon).
# =========================================================================

# --- App ---
APP_NAME=clothing-crm
APP_ENV=production
DEBUG=false
LOG_LEVEL=info

API_V1_PREFIX=/api/v1
# Frontend va backend bir domenda (nginx reverse proxy orqali) — origin bir xil.
BACKEND_CORS_ORIGINS=["https://negative.uz","https://www.negative.uz"]

# --- Domain / TLS ---
DOMAIN=negative.uz
# Let's Encrypt notification email — sertifikat tugashi haqida shu yerga xabar keladi
CERTBOT_EMAIL=admin@negative.uz
# 1 -> staging (test) sertifikat (rate limit kengroq); production'da 0 qoldiring
CERTBOT_STAGING=0

# --- Database (PostgreSQL) ---
POSTGRES_USER=crm_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=crm
# DATABASE_URL docker-compose ichida avtomatik tuziladi (postgres xost-nomidan).

# --- Redis / Celery ---
# REDIS_URL ham compose ichida (redis xost-nomi bilan).

# --- Security / JWT ---
# 64+ belgi tasodifiy. Misol: `openssl rand -hex 32`
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Boshlang'ich admin (seed) ---
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASS

# --- Media uploads ---
MEDIA_ROOT=/app/media
MEDIA_URL_PREFIX=/media
MAX_UPLOAD_MB=5
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/webp"]

# --- Gunicorn workers ---
WEB_CONCURRENCY=4

# --- Sentry (ixtiyoriy — bo'sh bo'lsa init bo'lmaydi) ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
# Frontend uchun alohida DSN (Vite build vaqtida inject qilinadi)
VITE_SENTRY_DSN=

# --- Nginx portlari ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# --- MinIO (S3-uyumli ob'ektlar saqlovchi) ---
MINIO_ROOT_USER=crm_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_MINIO_PASS
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Backup ---
BACKUP_DIR=/var/backups/crm
BACKUP_RETENTION_DAYS=14
